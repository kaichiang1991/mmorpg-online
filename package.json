{
  "name": "mmorpg-online",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:server": "npm run start:dev -w @mmo/server",
    "dev:client": "npm run dev -w @mmo/client",
    "lint": "oxlint apps/server/src apps/client/src packages/shared/src",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "oxlint": "^0.9.10",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
