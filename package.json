{
  "name": "mmorpg-online",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "dev:server": "npm run start:dev -w @mmo/server",
    "dev:client": "npm run dev -w @mmo/client",
    "lint": "oxlint apps/server/src apps/client/src packages/shared/src",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "oxlint": "^0.9.10",
    "prettier": "^3.3.3",
    "turbo": "^2.10.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2"
}
